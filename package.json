{
  "name": "ledger",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces run build",
    "test": "yarn workspaces run test",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migrate": "yarn workspace @ledger/shared migrate",
    "migrate:rollback": "yarn workspace @ledger/shared migrate:rollback",
    "dev": "concurrently -n api,worker,relay,audit -c cyan,green,yellow,magenta \"yarn dev:api\" \"yarn dev:settlement-worker\" \"yarn dev:outbox-relay\" \"yarn dev:audit-consumer\"",
    "dev:api": "yarn workspace @ledger/api dev",
    "dev:settlement-worker": "yarn workspace @ledger/settlement-worker dev",
    "dev:outbox-relay": "yarn workspace @ledger/outbox-relay dev",
    "dev:audit-consumer": "yarn workspace @ledger/audit-consumer dev",
    "test:e2e": "jest --runInBand --config e2e/jest.config.ts"
  },
  "devDependencies": {
    "@testcontainers/kafka": "^12.0.3",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.19.0"
  }
}
