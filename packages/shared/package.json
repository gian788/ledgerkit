    "migrate:make": "knex --knexfile knexfile.ts migrate:make --"
  },
  "dependencies": {
    "knex": "^3.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.2"
  }
}
